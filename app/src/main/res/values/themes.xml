<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — android.Theme.Material (dark), no AppCompat needed -->
    <style name="AppTheme" parent="android:Theme.Material">
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:colorPrimary">@color/surface</item>
        <item name="android:colorPrimaryDark">@color/bg</item>
        <item name="android:colorAccent">@color/primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:actionBarStyle">@style/AppActionBar</item>
    </style>

    <style name="AppActionBar" parent="android:Widget.Material.ActionBar">
        <item name="android:background">@color/surface</item>
        <item name="android:titleTextStyle">@style/AppActionBarTitle</item>
    </style>

    <style name="AppActionBarTitle" parent="android:TextAppearance.Material.Widget.ActionBar.Title">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- No-action-bar variant used for Setup/Login -->
    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
